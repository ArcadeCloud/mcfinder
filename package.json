{
  "name": "mcfinder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --target=es2020 --loader:.png=file --loader:.svg=file --asset-names=assets/[name] --public-path=/ --servedir=dist --serve=3000",
    "build": "bash build.sh",
    "preview": "npx -y serve dist"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@rollup/wasm-node": "^4.60.1",
    "esbuild": "^0.28.0",
    "leaflet": "^1.9.4"
  }
}
